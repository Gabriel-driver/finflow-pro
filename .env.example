# Copie este arquivo para .env e configure suas variáveis

# Ambiente (development/production)
NODE_ENV=development

# Porta do servidor (opcional, padrão 3000)
PORT=3000

# Chave secreta para JWT (USE UMA CHAVE FORTE E ÚNICA)
JWT_SECRET=sua-chave-secreta-aqui-troque-por-uma-chave-forte

# URL de conexão com PostgreSQL (Neon)
DATABASE_URL=postgresql://usuario:senha@ep-xxx-xxx.us-east-1.aws.neon.tech/neondb?sslmode=require

# Exemplo completo:
# DATABASE_URL=postgresql://finflow_user:abc123def456@ep-cool-darkness-123456.us-east-1.aws.neon.tech/neondb?sslmode=require
# JWT_SECRET=super-secret-jwt-key-change-this-in-production-123456789